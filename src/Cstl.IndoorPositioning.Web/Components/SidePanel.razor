@using Cstl.IndoorPositioning.Web.Services
@inject PositioningState State
@implements IDisposable

<aside class="sidebar">
    <div class="sidebar-header">
        <div class="logo">
            <span class="logo-icon">📡</span>
            <div>
                <div class="logo-title">Indoor Positioning</div>
                <div class="logo-sub">Cstl.IndoorPositioning</div>
            </div>
        </div>
        <div class="tab-row">
            <button class="tab @(ActiveTab == "beacons" ? "active" : "")" @onclick='() => ActiveTab = "beacons"'>Beacons</button>
            <button class="tab @(ActiveTab == "sim" ? "active" : "")" @onclick='() => ActiveTab = "sim"'>Simulator</button>
            <button class="tab @(ActiveTab == "live" ? "active" : "")" @onclick='() => ActiveTab = "live"'>Live</button>
        </div>
    </div>

    <div class="sidebar-body">
        @if (ActiveTab == "beacons")
        {
            <BeaconsTab />
        }
        else if (ActiveTab == "sim")
        {
            <SimulatorTab />
        }
        else
        {
            <LiveTab />
        }
    </div>

    @if (State.LastResult is not null)
    {
        <div class="sidebar-footer">
            <div class="result-row">
                <span class="result-label">Latitude</span>
                <span class="result-value">@State.LastResult.Latitude.ToString("F7")</span>
            </div>
            <div class="result-row">
                <span class="result-label">Longitude</span>
                <span class="result-value">@State.LastResult.Longitude.ToString("F7")</span>
            </div>
            <div class="result-row">
                <span class="result-label">Method</span>
                <span class="result-value accent">@State.LastResult.Method</span>
            </div>
            <div class="result-row">
                <span class="result-label">Beacons used</span>
                <span class="result-value">@State.LastResult.BeaconsUsed</span>
            </div>
        </div>
    }
</aside>

@code {
    private string ActiveTab { get; set; } = "beacons";

    protected override void OnInitialized() => State.OnChanged += Refresh;
    public void Dispose() => State.OnChanged -= Refresh;
    private void Refresh() => InvokeAsync(StateHasChanged);
}

<style>
    .sidebar {
        width: var(--sidebar-w);
        min-width: var(--sidebar-w);
        background: var(--surface);
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        height: 100vh;
        overflow: hidden;
    }

    .sidebar-header {
        padding: 16px;
        border-bottom: 1px solid var(--border);
        flex-shrink: 0;
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 14px;
    }

    .logo-icon { font-size: 24px; }
    .logo-title { font-weight: 700; font-size: 15px; color: var(--text); }
    .logo-sub   { font-size: 10px; color: var(--text-muted); letter-spacing: .05em; }

    .tab-row {
        display: flex;
        gap: 4px;
        background: var(--surface2);
        border-radius: var(--radius);
        padding: 3px;
    }

    .tab {
        flex: 1;
        background: transparent;
        color: var(--text-muted);
        padding: 6px 0;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 500;
        transition: all .15s;
    }

    .tab.active {
        background: var(--accent);
        color: #fff;
    }

    .tab:hover:not(.active) {
        color: var(--text);
        background: var(--border);
    }

    .sidebar-body {
        flex: 1;
        overflow-y: auto;
        padding: 12px;
    }

    .sidebar-footer {
        padding: 14px 16px;
        border-top: 1px solid var(--border);
        background: var(--surface2);
        flex-shrink: 0;
    }

    .result-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 3px 0;
    }

    .result-label { color: var(--text-muted); font-size: 11px; }
    .result-value { font-size: 12px; font-weight: 600; font-variant-numeric: tabular-nums; }
    .result-value.accent { color: var(--accent2); }
</style>
