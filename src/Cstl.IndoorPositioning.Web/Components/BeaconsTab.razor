@using Cstl.IndoorPositioning.Web.Model
@using Cstl.IndoorPositioning.Web.Services
@inject PositioningState State
@implements IDisposable

<div class="section-title">Add Beacon</div>
<div class="form-group">
    <label>MAC Address</label>
    <input type="text" @bind="NewMac" placeholder="AA:BB:CC:DD:EE:FF" />
</div>
<div class="form-group">
    <label>Label (optional)</label>
    <input type="text" @bind="NewLabel" placeholder="e.g. Beacon A" />
</div>
<div class="form-row">
    <div class="form-group">
        <label>Latitude</label>
        <input type="number" step="0.000001" @bind="NewLat" />
    </div>
    <div class="form-group">
        <label>Longitude</label>
        <input type="number" step="0.000001" @bind="NewLon" />
    </div>
</div>
<div class="form-row">
    <div class="form-group">
        <label>TxPower (dBm)</label>
        <input type="number" @bind="NewTxPower" />
    </div>
</div>

@if (!string.IsNullOrEmpty(AddError))
{
    <div class="error-msg">@AddError</div>
}

<button class="btn-primary full" @onclick="AddBeacon">+ Add Beacon</button>

<div class="hint-text">Or click on the map to place at that position.</div>

@if (State.Beacons.Count > 0)
{
    <div class="section-title" style="margin-top:20px">
        Anchors
        <span class="badge">@State.Beacons.Count</span>
    </div>

    @foreach (var b in State.Beacons)
    {
        <div class="beacon-card @(!b.Active ? "inactive" : "")">
            <div class="beacon-card-header">
                <div>
                    <div class="beacon-name">@(string.IsNullOrEmpty(b.Label) ? b.MAC : b.Label)</div>
                    <div class="beacon-mac">@b.MAC</div>
                </div>
                <div class="beacon-actions">
                    <button class="btn-icon @(b.Active ? "active" : "")" title="Toggle" @onclick="() => Toggle(b.MAC)">
                        @(b.Active ? "●" : "○")
                    </button>
                    <button class="btn-icon danger" title="Remove" @onclick="() => Remove(b.MAC)">✕</button>
                </div>
            </div>
            <div class="beacon-coords">
                @b.Latitude.ToString("F6"), @b.Longitude.ToString("F6")
            </div>
            <div class="beacon-dist">
                TxPower @b.TxPower dBm · RSSI @b.RSSI dBm
                → <strong>@b.EstimatedDistanceMeters.ToString("F1") m</strong>
            </div>
        </div>
    }

    <button class="btn-danger full" style="margin-top:8px" @onclick="ClearAll">Clear all</button>
}

@code {
    private string NewMac { get; set; } = string.Empty;
    private string NewLabel { get; set; } = string.Empty;
    private double NewLat { get; set; } = -23.5505;
    private double NewLon { get; set; } = -46.6333;
    private int NewTxPower { get; set; } = -59;
    private string AddError { get; set; } = string.Empty;

    protected override void OnInitialized()
    {
        State.OnChanged += Refresh;
        MapView.PendingMapClick += OnMapClick;
    }

    public void Dispose()
    {
        State.OnChanged -= Refresh;
        MapView.PendingMapClick -= OnMapClick;
    }

    private void Refresh() => InvokeAsync(StateHasChanged);

    private void OnMapClick(double lat, double lon)
    {
        NewLat = lat;
        NewLon = lon;
        InvokeAsync(StateHasChanged);
    }

    private void AddBeacon()
    {
        AddError = string.Empty;

        if (string.IsNullOrWhiteSpace(NewMac))
        { AddError = "MAC address is required."; return; }

        if (State.Beacons.Any(b => b.MAC.Equals(NewMac.Trim(), StringComparison.OrdinalIgnoreCase)))
        { AddError = "A beacon with this MAC already exists."; return; }

        State.AddBeacon(new BeaconViewModel
        {
            MAC = NewMac.Trim().ToUpperInvariant(),
            Label = NewLabel.Trim(),
            Latitude = NewLat,
            Longitude = NewLon,
            TxPower = NewTxPower,
            RSSI = -70
        });

        NewMac = string.Empty;
        NewLabel = string.Empty;
        NewLon += 0.0002;

        State.Recalculate();
    }

    private void Remove(string mac)
    {
        State.RemoveBeacon(mac);
        State.Recalculate();
    }

    private void Toggle(string mac)
    {
        State.ToggleBeaconActive(mac);
        State.Recalculate();
    }

    private void ClearAll()
    {
        foreach (var b in State.Beacons.ToList())
            State.RemoveBeacon(b.MAC);
        State.Recalculate();
    }
}

<style>
    .section-title {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: var(--text-muted);
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .badge {
        background: var(--accent);
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        padding: 1px 6px;
        border-radius: 10px;
        letter-spacing: 0;
    }

    .form-group {
        margin-bottom: 8px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .form-group label {
        font-size: 11px;
        color: var(--text-muted);
        font-weight: 500;
    }

    .form-group input, .form-group select {
        padding: 7px 10px;
        width: 100%;
    }

    .form-row {
        display: flex;
        gap: 8px;
    }

    .form-row .form-group { flex: 1; }

    .btn-primary {
        background: var(--accent);
        color: #fff;
        padding: 8px 16px;
        font-weight: 600;
    }

    .btn-primary:hover { background: #2563eb; }

    .btn-danger {
        background: transparent;
        border: 1px solid var(--danger);
        color: var(--danger);
        padding: 7px 16px;
        font-weight: 500;
    }

    .btn-danger:hover { background: #ef444422; }

    .full { width: 100%; margin-top: 4px; }

    .hint-text {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 6px;
        margin-bottom: 4px;
    }

    .error-msg {
        color: var(--danger);
        font-size: 12px;
        margin-bottom: 6px;
    }

    .beacon-card {
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 10px 12px;
        margin-bottom: 6px;
        transition: opacity .15s;
    }

    .beacon-card.inactive { opacity: .45; }

    .beacon-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 4px;
    }

    .beacon-name { font-weight: 600; font-size: 13px; }
    .beacon-mac  { font-size: 10px; color: var(--text-muted); font-variant-numeric: tabular-nums; margin-top: 1px; }
    .beacon-coords { font-size: 11px; color: var(--text-muted); margin-bottom: 2px; }
    .beacon-dist   { font-size: 11px; color: var(--text-muted); }
    .beacon-dist strong { color: var(--accent2); }

    .beacon-actions { display: flex; gap: 4px; }

    .btn-icon {
        background: var(--border);
        color: var(--text-muted);
        width: 26px; height: 26px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 6px;
        font-size: 12px;
        padding: 0;
    }

    .btn-icon.active { background: #3b82f622; color: var(--accent); }
    .btn-icon.danger:hover { background: #ef444422; color: var(--danger); }
    .btn-icon:hover { background: var(--surface); }
</style>
